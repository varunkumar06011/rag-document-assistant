# Groq API (FREE — sign up at console.groq.com, takes 2 minutes)
GROQ_API_KEY=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

# Embedding model (runs 100% locally, no key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM model via Groq (free)
LLM_MODEL=llama3-8b-8192

# Chunking settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Retrieval settings
TOP_K_RETRIEVAL=6
TOP_K_RERANK=3

# Paths
VECTORSTORE_PATH=./data/vectorstore
UPLOADS_PATH=./data/uploads
